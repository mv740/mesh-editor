{
  "name": "@mv740/mesh-editor",
  "version": "0.0.1",
  "description": "Interactive 3D mesh editor component for React",
  "type": "module",
  "keywords": [
    "react",
    "threejs",
    "mesh",
    "editor",
    "3d"
  ],
  "license": "MIT",
  "homepage": "https://github.com/mv740/mesh-editor#readme",
  "bugs": {
    "url": "https://github.com/mv740/mesh-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mv740/mesh-editor.git"
  },
  "author": "Michal Wozniak <michal@wozniak.dev>",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./style.css": "./dist/style.css",
    "./dist/style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "style": "dist/style.css",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix",
    "build:js": "tsdown",
    "build:css": "npx @tailwindcss/cli -i ./src/index.css -o ./dist/style.css",
    "build": "npm run build:js && npm run build:css",
    "dev": "tsdown --watch",
    "playground": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts",
    "playground:preview": "vite preview --config playground/vite.config.ts",
    "playground:host": "vite --host 0.0.0.0 --config playground/vite.config.ts",
    "test": "vitest --browser.headless",
    "test:coverage": "vitest --coverage --browser.headless",
    "test:unit": "vitest --project unit",
    "test:e2e": "vitest --project e2e",
    "typecheck": "tsc --noEmit",
    "format": "npm --cache --write .",
    "release": "npm publish",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "dependencies": {
    "@kninnug/constrainautor": "^4.0.1",
    "@radix-ui/primitive": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-primitive": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@react-three/drei": "^10.7.4",
    "@react-three/fiber": "^9.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "delaunator": "^5.0.1",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.542.0",
    "react-dropzone": "^14.3.8",
    "react-hotkeys-hook": "^5.1.0",
    "tailwind-merge": "^3.3.1",
    "three": "^0.179.0",
    "tw-animate-css": "^1.3.4"
  },
  "devDependencies": {
    "@react-three/test-renderer": "^9.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@sxzz/eslint-config": "^7.0.1",
    "@sxzz/prettier-config": "^2.2.1",
    "@tailwindcss/cli": "^4.1.13",
    "@tailwindcss/vite": "^4.1.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/delaunator": "^5.0.3",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.4",
    "@types/three": "^0.178.0",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.26.0",
    "happy-dom": "^17.4.6",
    "playwright": "^1.53.1",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "semantic-release": "^24.2.9",
    "tailwindcss": "^4.1.10",
    "tsdown": "^0.11.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "npm:rolldown-vite@7.1.11",
    "vitest": "^3.1.3",
    "vitest-browser-react": "^0.3.0",
    "vitest-canvas-mock": "^0.3.3"
  },
  "prettier": "@sxzz/prettier-config"
}
